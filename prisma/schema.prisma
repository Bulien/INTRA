generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String            @id @default(cuid())
  username                String?           @unique
  name                    String?
  email                   String?           @unique
  emailVerified           DateTime?
  image                   String?
  password                String?
  role                    String            @default("user")
  bannedUntil             DateTime?
  createdAt               DateTime          @default(now())
  accounts                Account[]
  gameResults             GameResult[]
  sessions                Session[]
  teamBuilderGamesCreated TeamBuilderGame[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RegistrationAttempt {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

model GameResult {
  id        String   @id @default(cuid())
  userId    String
  gameType  String
  score     Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, gameType])
  @@index([gameType])
}

model RankingPlayer {
  id        String   @id @default(cuid())
  name      String
  gameType  String
  season    Int      @default(1)
  scores    String   @default("[]")
  updatedAt DateTime @updatedAt

  @@unique([name, gameType, season])
  @@index([gameType, season])
}

model GameSeason {
  gameType  String @id
  maxSeason Int    @default(1)
}

model SeasonMeta {
  gameType           String
  season             Int
  validatedIndices   String @default("[]")
  validatedPlayerIds String @default("[]")

  @@id([gameType, season])
}

model TeamBuilderGame {
  id          String   @id @default(cuid())
  gameType    String
  season      Int
  createdById String
  teamA       String
  teamB       String
  status      String   @default("pending")
  winner      String?
  createdAt   DateTime @default(now())
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

model PlayerGameRating {
  id         String   @id @default(cuid())
  playerName String
  gameType   String
  rating     Int
  gameId     String
  createdAt  DateTime @default(now())

  @@index([playerName, gameType])
}
